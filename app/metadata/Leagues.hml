---
kind: BooleanExpressionType
version: v1
definition:
  name: LeaguesBoolExp
  operand:
    object:
      type: Leagues
      comparableFields:
        - fieldName: acquisitionBudget
          booleanExpressionType: Int4BoolExp
        - fieldName: createdAt
          booleanExpressionType: TimestampBoolExp
        - fieldName: draftAuctionBudget
          booleanExpressionType: Int4BoolExp
        - fieldName: leagueId
