---
kind: ObjectType
version: v1
definition:
  name: Leagues
  fields:
    - name: acquisitionBudget
      type: Int32
    - name: createdAt
      type: Timestamp
    - name: draftAuctionBudget
      type: Int32
    - name: leagueId
      type: Int32!
    - name: numTeams
      type: Int32
    - name: rosterSettings
      type: Json
    - name: scoringPeriodId
      type: Int32
    - name: seasonId
      type: Int32!
    - name: updatedAt
      type: Timestamp
    - name: leagueName
      type: String_1
  graphql:
    typeName: Leagues
    inputTypeName: LeaguesInput
  dataConnectorTypeMapping:
    - dataConnectorName: neon_mtbl
      dataConnectorObjectType: leagues
      fieldMapping:
        acquisitionBudget:
          column:
            name: acquisition_budget
        createdAt:
          column:
            name: created_at
        draftAuctionBudget:
          column:
            name: draft_auction_budget
        leagueId:
          column:
            name: league_id
        numTeams:
          column:
            name: num_teams
        rosterSettings:
          column:
            name: roster_settings
        scoringPeriodId:
          column:
            name: scoring_period_id
        seasonId:
          column:
            name: season_id
        updatedAt:
          column:
            name: updated_at
        leagueName:
          column:
            name: league_name

---
kind: TypePermissions
version: v1
definition:
  typeName: Leagues
  permissions:
    - role: admin
      output:
        allowedFields:
          - acquisitionBudget
          - createdAt
          - draftAuctionBudget
          - leagueId
          - numTeams
          - rosterSettings
          - scoringPeriodId
          - seasonId
          - updatedAt
          - leagueName

---
kind: AggregateExpression
version: v1
definition:
  name: LeaguesAggExp
  operand:
    object:
      aggregatedType: Leagues
      aggregatableFields:
        - fieldName: acquisitionBudget
          aggregateExpression: Int4AggExp
        - fieldName: createdAt
          aggregateExpression: TimestampAggExp
        - fieldName: draftAuctionBudget
          aggregateExpression: Int4AggExp
        - fieldName: leagueId
          aggregateExpression: Int4AggExp
        - fieldName: numTeams
          aggregateExpression: Int4AggExp
        - fieldName: rosterSettings
          aggregateExpression: JsonbAggExp
        - fieldName: scoringPeriodId
          aggregateExpression: Int4AggExp
        - fieldName: seasonId
          aggregateExpression: Int4AggExp
        - fieldName: updatedAt
          aggregateExpression: TimestampAggExp
        - fieldName: leagueName
          aggregateExpression: VarcharAggExp
  count:
    enable: true
    returnType: Int64
  graphql:
    selectTypeName: LeaguesAggExp

---
kind: OrderByExpression
version: v1
definition:
  name: LeaguesOrderByExp
  operand:
    object:
      orderedType: Leagues
      orderableFields:
        - fieldName: acquisitionBudget
          orderByExpression: Int32OrderByExp
        - fieldName: createdAt
          orderByExpression: TimestampOrderByExp
        - fieldName: draftAuctionBudget
