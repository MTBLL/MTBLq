        - fieldName: rosterSettings
          orderByExpression: JsonOrderByExp
        - fieldName: scoringPeriodId
          orderByExpression: Int32OrderByExp
        - fieldName: seasonId
          orderByExpression: Int32OrderByExp
        - fieldName: updatedAt
          orderByExpression: TimestampOrderByExp
        - fieldName: leagueName
          orderByExpression: String1OrderByExp
      orderableRelationships: []
  graphql:
    expressionTypeName: LeaguesOrderByExp

---
kind: Model
version: v2
definition:
  name: Leagues
  objectType: Leagues
  source:
    dataConnectorName: neon_mtbl
    collection: leagues
  filterExpressionType: LeaguesBoolExp
  aggregateExpression: LeaguesAggExp
  orderByExpression: LeaguesOrderByExp
  graphql:
    selectMany:
      queryRootField: leagues
      subscription:
        rootField: leagues
    selectUniques:
      - queryRootField: leaguesByLeagueId
        uniqueIdentifier:
          - leagueId
        subscription:
          rootField: leaguesByLeagueId
    filterInputTypeName: LeaguesFilterInput
    aggregate:
      queryRootField: leaguesAggregate
      subscription:
        rootField: leaguesAggregate

---
kind: ModelPermissions
version: v1
definition:
  modelName: Leagues
  permissions:
    - role: admin
      select:
        filter: null
        allowSubscriptions: true

