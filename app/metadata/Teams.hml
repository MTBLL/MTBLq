          aggregateExpression: Int4AggExp
        - fieldName: gamesBack
          aggregateExpression: NumericAggExp
        - fieldName: leagueId
          aggregateExpression: Int4AggExp
        - fieldName: losses
          aggregateExpression: Int4AggExp
        - fieldName: owners
          aggregateExpression: JsonbAggExp
        - fieldName: primaryOwner
          aggregateExpression: VarcharAggExp
        - fieldName: seasonId
          aggregateExpression: Int4AggExp
        - fieldName: teamAbbrev
          aggregateExpression: VarcharAggExp
        - fieldName: teamId
          aggregateExpression: Int4AggExp
        - fieldName: teamLogo
          aggregateExpression: VarcharAggExp
        - fieldName: teamName
          aggregateExpression: VarcharAggExp
        - fieldName: ties
