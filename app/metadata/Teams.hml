---
kind: AggregateExpression
version: v1
definition:
  name: TeamsAggExp
  operand:
    object:
      aggregatedType: Teams
      aggregatableFields:
        - fieldName: acquisitions
          aggregateExpression: Int4AggExp
        - fieldName: budgetRemaining
          aggregateExpression: Int4AggExp
        - fieldName: budgetSpent
          aggregateExpression: Int4AggExp
        - fieldName: createdAt
          aggregateExpression: TimestampAggExp
