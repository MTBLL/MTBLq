kind: DataConnectorLink
version: v1
definition:
  name: neon_mtbl
  url:
    readWriteUrls:
      read:
        valueFromEnv: APP_NEON_MTBL_READ_URL
      write:
        valueFromEnv: APP_NEON_MTBL_WRITE_URL
  headers:
    Authorization:
      valueFromEnv: APP_NEON_MTBL_AUTHORIZATION_HEADER
  schema:
    version: v0.2
    schema:
      capabilities:
        query:
          aggregates:
            count_scalar_type: int8
      collections:
        - arguments: {}
          name: league_scoring_categories
          type: league_scoring_categories
          uniqueness_constraints:
            league_scoring_categories_league_id_stat_type_stat_id_key:
              unique_columns:
                - league_id
                - stat_id
                - stat_type
            league_scoring_categories_pkey:
              unique_columns:
                - id
        - arguments: {}
          name: leagues
          type: leagues
          uniqueness_constraints:
            leagues_pkey:
              unique_columns:
                - league_id
        - arguments: {}
          name: matchups
          type: matchups
          uniqueness_constraints:
            matchups_pkey:
              unique_columns:
                - matchup_id
        - arguments: {}
          name: neon_auth_users_sync
          type: neon_auth_users_sync
          uniqueness_constraints:
            users_sync_pkey:
              unique_columns:
                - id
        - arguments: {}
          name: parquet_artifacts
          type: parquet_artifacts
          uniqueness_constraints:
            parquet_artifacts_pkey:
              unique_columns:
                - id
            parquet_artifacts_table_name_key:
              unique_columns:
                - table_name
        - arguments: {}
          name: player_fantasy_assignments
          type: player_fantasy_assignments
          uniqueness_constraints:
            player_fantasy_assignments_pkey:
              unique_columns:
                - id
            player_fantasy_assignments_player_id_league_id_season_id_key:
              unique_columns:
                - league_id
                - player_id
                - season_id
        - arguments: {}
          name: player_projections
          type: player_projections
          uniqueness_constraints:
            player_projections_pkey:
              unique_columns:
                - id
            player_projections_player_id_season_id_projection_source_pr_key:
              unique_columns:
                - player_id
                - player_type
                - projection_period
                - projection_source
                - season_id
        - arguments: {}
          name: player_stats_batting
          type: player_stats_batting
          uniqueness_constraints:
            player_stats_batting_pkey:
              unique_columns:
                - id
            player_stats_batting_player_id_season_id_stat_period_key:
              unique_columns:
                - player_id
                - season_id
                - stat_period
        - arguments: {}
          name: player_stats_pitching
          type: player_stats_pitching
          uniqueness_constraints:
            player_stats_pitching_pkey:
              unique_columns:
                - id
            player_stats_pitching_player_id_season_id_stat_period_key:
              unique_columns:
                - player_id
                - season_id
                - stat_period
        - arguments: {}
          name: player_valuation_details
          type: player_valuation_details
          uniqueness_constraints:
            player_valuation_details_pkey:
              unique_columns:
                - id
            player_valuation_details_valuation_id_stat_category_key:
              unique_columns:
                - stat_category
                - valuation_id
        - arguments: {}
          name: player_valuations
          type: player_valuations
          uniqueness_constraints:
            player_valuations_pkey:
              unique_columns:
                - id
            player_valuations_player_id_season_id_primary_position_valu_key:
              unique_columns:
                - player_id
                - primary_position
                - season_id
                - valuation_type
        - arguments: {}
          name: players
          type: players
          uniqueness_constraints:
            players_pkey:
              unique_columns:
                - id_espn
        - arguments: {}
          name: position_summary
          type: position_summary
          uniqueness_constraints:
            position_summary_pkey:
              unique_columns:
                - id
            position_summary_position_valuation_type_key:
              unique_columns:
                - position
                - valuation_type
        - arguments: {}
          name: roster_slots
          type: roster_slots
          uniqueness_constraints:
            roster_slots_pkey:
              unique_columns:
                - id
            roster_slots_team_id_player_id_season_id_key:
              unique_columns:
                - player_id
                - season_id
                - team_id
        - arguments: {}
          name: teams
          type: teams
          uniqueness_constraints:
            teams_pkey:
              unique_columns:
                - team_id
